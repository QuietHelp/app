# ---- Backend (Spring Boot) ----
# Used by the browser to reach the backend (REST + WebSocket).
# Local dev: point at your local Spring Boot on :8080.
# Production: point at your public backend URL (e.g. https://api.quiet-help.life).
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ---- AI companion (Google Gemini) ----
# SERVER-SIDE ONLY. Do NOT prefix with NEXT_PUBLIC_ or this will leak to the browser.
# Required for /api/chat and /api/moderate. Get a free key at:
#   https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: override the Gemini model. Default is gemini-2.5-flash.
# AI_MODEL=gemini-2.0-flash

# ---- Moderation cache (Redis) ----
# Optional. Used by /api/moderate to cache LLM verdicts so repeated phrases
# (greetings, short replies, etc.) skip the Gemini call. If unset or unreachable,
# moderation still works — it just falls back to calling Gemini every time.
# Local dev: point at the Redis started by `docker compose up -d` in /backend.
REDIS_HOST=localhost
REDIS_PORT=6379
# MODERATION_CACHE_TTL_SECONDS=604800
